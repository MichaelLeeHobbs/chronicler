{
  "name": "@ubercode/chronicler",
  "version": "1.0.1",
  "description": "Type-safe structured logging with event definitions, correlations, and field validation for Node.js",
  "keywords": [
    "logging",
    "structured-logging",
    "type-safe",
    "typescript",
    "events",
    "correlation",
    "observability",
    "audit",
    "node"
  ],
  "license": "MIT",
  "author": "MichaelLeeHobbs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MichaelLeeHobbs/chronicler.git"
  },
  "bugs": {
    "url": "https://github.com/MichaelLeeHobbs/chronicler/issues"
  },
  "homepage": "https://github.com/MichaelLeeHobbs/chronicler#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "chronicler": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "dev": "tsup --watch",
    "build": "pnpm run clean && tsup",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "prepare": "husky",
    "prepublishOnly": "pnpm run check && pnpm run build",
    "preversion": "pnpm run check",
    "postversion": "git push && git push --tags",
    "version:major": "npm version major",
    "version:minor": "npm version minor",
    "version:patch": "npm version patch",
    "dry-run": "npm pack --dry-run"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,cjs,mjs}": [
      "pnpm exec eslint --fix --max-warnings=0"
    ],
    "tests/**/*.{ts,tsx,js,jsx,cjs,mjs}": [
      "pnpm exec eslint --fix --max-warnings=0"
    ],
    "./*.{ts,tsx,js,cjs,mjs}": [
      "pnpm exec eslint --fix --max-warnings=0"
    ],
    "*.{json,md,yml,yaml,ts,tsx,js,jsx,cjs,mjs}": [
      "pnpm exec prettier --write"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@typescript-eslint/eslint-plugin": "8.46.4",
    "@typescript-eslint/parser": "8.46.4",
    "@vitest/coverage-v8": "4.0.9",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "husky": "9.1.7",
    "lint-staged": "16.2.6",
    "prettier": "3.6.2",
    "rimraf": "6.1.0",
    "tsup": "8.5.1",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.0.9"
  },
  "dependencies": {
    "commander": "14.0.2"
  },
  "packageManager": "pnpm@10.18.0"
}
